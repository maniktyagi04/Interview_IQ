// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String            @id @default(uuid())
  name            String
  email           String            @unique
  password        String
  role            String            @default("USER") // USER, ADMIN
  profileImage    String?
  status          String            @default("ACTIVE") // ACTIVE, BLOCKED
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  interviews      Interview[]
  resumes         Resume[]
  notes           Note[]
  createdQuestions Question[]       @relation("CreatedQuestions")
  approvedReports  InterviewReport[] @relation("ApprovedReports")
  analytics       Analytics?
}

model Question {
  id          String            @id @default(uuid())
  title       String
  description String            @db.Text
  domain      String            // Frontend Development, Backend Development, Full Stack Development, AI/ML Engineering, Data Science
  difficulty  String            // Easy, Medium, Hard
  createdBy   String?
  creator     User?             @relation("CreatedQuestions", fields: [createdBy], references: [id], onDelete: SetNull)
  answers     InterviewAnswer[]
  createdAt   DateTime          @default(now())
}

model Interview {
  id          String            @id @default(uuid())
  userId      String
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  domain      String
  difficulty  String
  status      String            @default("PENDING_EVALUATION") // PENDING_EVALUATION, PENDING_REVIEW, APPROVED, REJECTED
  submittedAt DateTime          @default(now())
  
  answers     InterviewAnswer[]
  report      InterviewReport?
}

model InterviewAnswer {
  id          String    @id @default(uuid())
  interviewId String
  interview   Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  questionId  String
  question    Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answer      String    @db.Text
  score       Int?      // AI-assigned score (1-10) for this specific answer
  feedback    String?   @db.Text // AI evaluation detail (accuracy, quality, etc.) for this answer
}

model InterviewReport {
  id             String    @id @default(uuid())
  interviewId    String    @unique
  interview      Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  aiScore        Float
  strengths      String    @db.Text // JSON string or comma-separated list
  weaknesses     String    @db.Text // JSON string or comma-separated list
  suggestions    String    @db.Text // JSON string or comma-separated list
  summary        String    @db.Text
  approvalStatus String    @default("PENDING") // PENDING, APPROVED, REJECTED
  approvedBy     String?
  approver       User?     @relation("ApprovedReports", fields: [approvedBy], references: [id], onDelete: SetNull)
  manualFeedback String?   @db.Text
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Resume {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fileUrl     String
  parsedText  String?  @db.Text
  aiAnalysis  String?  @db.Text // JSON string
  createdAt   DateTime @default(now())
}

model Note {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Analytics {
  id                  String @id @default(uuid())
  userId              String @unique
  user                User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  averageScore        Float  @default(0.0)
  interviewsCompleted Int    @default(0)
  domainBreakdown     String? @db.Text // JSON string representing performance per domain
}
